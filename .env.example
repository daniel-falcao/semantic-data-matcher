# ─────────────────────────────────────────────
#  Semantic Data Matcher — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Path to the domain reference file (.xlsx or .csv)
DOMAIN_PATH=data/domain/DOMAIN.xlsx

# Folders for batch CLI mode
INPUT_FOLDER=data/input
OUTPUT_FOLDER=data/output
LOGS_FOLDER=logs

# NLP settings
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
THRESHOLD=0.75

# Column name in input files that holds the text to be matched
SOURCE_COLUMN=description

# API server
API_HOST=0.0.0.0
PORT=8000
